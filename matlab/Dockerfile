# syntax=docker/dockerfile:1

# MATLAB release tag for the Docker image (lowercase, as used on Docker Hub)
ARG MATLAB_DOCKER_TAG=r2023b

FROM mathworks/matlab-deep-learning:${MATLAB_DOCKER_TAG}

USER root

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    TZ=Etc/UTC \
    PYTHONUNBUFFERED=1 \
    MPLCONFIGDIR=/tmp/matplotlib

# System dependencies
RUN set -eux; \
    apt-get update -o Acquire::AllowInsecureRepositories=true -o Acquire::Check-Valid-Until=false; \
    apt-get install -y --no-install-recommends --allow-unauthenticated \
        ca-certificates \
        curl \
        gnupg \
        python3 \
        python3-venv \
        python3-pip \
        python3-dev \
        build-essential \
        git \
        wget \
        unzip \
        libatlas-base-dev \
        libfreetype6-dev \
        libxft-dev \
        libxext6 \
        libxrender1 \
        libsm6 \
        libxt6 \
        libffi-dev \
        libssl-dev \
        libxml2-dev \
        libcurl4-openssl-dev \
        libbz2-dev \
        liblzma-dev \
        zlib1g-dev; \
    rm -rf /var/lib/apt/lists/*

ENV VIRTUAL_ENV=/opt/venv
RUN python3 -m venv "${VIRTUAL_ENV}"
ENV PATH="${VIRTUAL_ENV}/bin:${PATH}"

COPY matlab/requirements.txt /tmp/requirements.txt
RUN pip install --upgrade pip \
 && pip install --no-cache-dir -r /tmp/requirements.txt \
 && rm /tmp/requirements.txt

# Shared data dir + matlab-proxy state + workspace symlink + startup script
RUN mkdir -p /data /var/lib/matlab-proxy \
 && chown matlab:matlab /data /var/lib/matlab-proxy \
 && ln -sfn /data /home/matlab/UnifiedWorkspaces \
 && printf "%s\n" \
    "%% Auto-generated by unified/matlab/Dockerfile" \
    "try" \
    "    cd('/data');" \
    "catch ME" \
    "    warning('Failed to change directory to /data: %s', ME.message);" \
    "end" \
    > /home/matlab/startup.m \
 && chown matlab:matlab /home/matlab/startup.m

WORKDIR /app
COPY . /app

ENV UNIFIED_DATA_ROOT=/data \
    MATLAB_STATE_FILE=/var/lib/matlab-proxy/state.json \
    MWI_APP_PORT=9100 \
    MWI_APP_HOST=0.0.0.0

USER matlab

ENTRYPOINT ["python", "/app/matlab/service.py"]